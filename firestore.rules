/**
 * This ruleset enforces a security model for the CrimeShield application.
 * For this demo, it allows any authenticated user (including anonymous users)
 * to read and create detection results, enabling a global, real-time dashboard.
 *
 * Core Philosophy (Demo):
 * To support a live-updating dashboard for all users, results from the
 * detection engines are stored in global collections. Access is granted to any
 * authenticated user, with anonymous sign-in handled automatically on the client.
 * This provides a simple but effective security model for demonstration purposes.
 *
 * Data Structure:
 * - /mediaDetectionResults/{resultId} : Stores deepfake detection results.
 * - /chatDetectionResults/{resultId} : Stores scam chat detection results.
 *
 * Key Security Decisions for Demo:
 * - Anonymous Access: The app automatically signs users in anonymously to meet
 *   the `isSignedIn()` requirement.
 * - Global Read/Create: Any authenticated user can create new detection
 *   results and read all existing results. This is what powers the live dashboard.
 * - No Update/Delete: To maintain data integrity for the demo, clients are not
 *   allowed to modify or delete existing records.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated.
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for the global collections used in the demo.
    // Any authenticated user (including anonymous) can read and create records.

    match /mediaDetectionResults/{resultId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if false;
    }

    match /chatDetectionResults/{resultId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if false;
    }

    // The rules below are for a more robust multi-user production app.
    // They are not used in the current demo but are kept for reference.

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow get, list, update, delete: if false;
    }

    match /users/{userId}/{document=**} {
       allow read, write: if isOwner(userId);
    }
  }
}
